{
  "description": "Engineering board automation — loads board state at session start, validates entries on write, primes intake context on debugging prompts, and routes per-turn findings to per-session scratch boards on Stop. v0.2.2 M2.2.b adds mode-routing on Stop (pm/worker/passive); the long procedure lives in hooks/stop-hook-procedure.md so the visible chat isn't paged each turn.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/board-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/board-validate-entry.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/board-prompt-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PLUGIN_ROOT/hooks/scripts/board-stop-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
